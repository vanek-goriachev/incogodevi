     "fontSize": 13, "fontFamily": 3, "textAlign": "center", "verticalAlign": "top",
     "strokeColor": "#dbeafe", "backgroundColor": "transparent",
     "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
