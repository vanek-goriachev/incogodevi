     "link": null, "locked": false, "containerId": null, "lineHeight": 1.3},
    {"type": "rectangle", "id": "spa_code_bg",
     "x": 380, "y": 535, "width": 380, "height": 130,
     "strokeColor": "#1e293b", "backgroundColor": "#1e293b",
