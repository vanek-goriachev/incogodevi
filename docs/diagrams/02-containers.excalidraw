    {"type": "text", "id": "backend_code",
     "x": 910, "y": 550, "width": 440, "height": 110,
     "text": "// public endpoints\nPOST   /api/projects                → {project_id}\nPOST   /api/projects/{id}/analyze  → text/event-stream\nGET    /api/projects/{id}/graph    → application/json\nGET    /api/projects/{id}/dead-code\nDELETE /api/projects/{id}",
     "originalText": "// public endpoints\nPOST   /api/projects                → {project_id}\nPOST   /api/projects/{id}/analyze  → text/event-stream\nGET    /api/projects/{id}/graph    → application/json\nGET    /api/projects/{id}/dead-code\nDELETE /api/projects/{id}",
     "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
