    {"type": "text", "id": "spa_code",
     "x": 390, "y": 545, "width": 360, "height": 110,
     "text": "// client flow (pseudocode)\nconst {project_id} = await POST('/api/projects', zip)\nconst es = new EventSource(\n  `/api/projects/${project_id}/analyze`)\nes.on('partial_graph', data => cy.add(data.nodes, data.edges))\nes.on('done', () => enableExports())",
     "originalText": "// client flow (pseudocode)\nconst {project_id} = await POST('/api/projects', zip)\nconst es = new EventSource(\n  `/api/projects/${project_id}/analyze`)\nes.on('partial_graph', data => cy.add(data.nodes, data.edges))\nes.on('done', () => enableExports())",
     "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
     "strokeColor": "#22c55e", "backgroundColor": "transparent",
     "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
