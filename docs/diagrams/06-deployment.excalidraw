    },
    {
      "type": "text",
      "id": "s1_b",
      "x": 70,
      "y": 195,
      "width": 320,
      "height": 200,
      "text": "WORKDIR /web\nCOPY web/package*.json ./\nRUN npm ci --no-audit\nCOPY web/ ./\nRUN npm run build\n    \u2192 emits /web/dist/\n       \u251c index.html\n       \u251c assets/*.js (Vite hash)\n       \u2514 assets/*.css",
      "originalText": "WORKDIR /web\nCOPY web/package*.json ./\nRUN npm ci --no-audit\nCOPY web/ ./\nRUN npm run build\n    \u2192 emits /web/dist/\n       \u251c index.html\n       \u251c assets/*.js (Vite hash)\n       \u2514 assets/*.css",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#0f172a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 600011,
      "version": 1,
      "versionNonce": 600012,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "containerId": null,
      "lineHeight": 1.3
    },
