    {
      "type": "text",
      "id": "proc_b",
      "x": 140,
      "y": 770,
      "width": 420,
      "height": 140,
      "text": "main goroutine: net/http.ListenAndServe(:8080)\nembed.FS holds compiled SPA at / (GET \u2192 index.html)\npackages.Load uses $GOCACHE if present, otherwise builds from scratch\nper request: spawns worker goroutine, ctx.Context carries deadline",
      "originalText": "main goroutine: net/http.ListenAndServe(:8080)\nembed.FS holds compiled SPA at / (GET \u2192 index.html)\npackages.Load uses $GOCACHE if present, otherwise builds from scratch\nper request: spawns worker goroutine, ctx.Context carries deadline",
