    {
      "type": "text",
      "id": "s1_t",
      "x": 70,
      "y": 168,
      "width": 320,
      "height": 22,
      "text": "Stage 1 \u2014 frontend (node:24-alpine)",
      "originalText": "Stage 1 \u2014 frontend (node:24-alpine)",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "top",
      "strokeColor": "#1e40af",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 600009,
      "version": 1,
      "versionNonce": 600010,
      "isDeleted": false,
