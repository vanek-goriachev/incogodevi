    },
    {
      "type": "text",
      "id": "s3_b",
      "x": 850,
      "y": 195,
      "width": 320,
      "height": 200,
      "text": "FROM gcr.io/distroless/static-debian12\nCOPY --from=stage2 /out/go-viz /go-viz\nUSER nonroot:nonroot\nENV PORT=8080\nEXPOSE 8080\nENTRYPOINT [\"/go-viz\"]\n\nImage size: ~12\u201318 MB (Go binary only)\nNo shell, no package manager,\nno writable paths except $TMPDIR.",
      "originalText": "FROM gcr.io/distroless/static-debian12\nCOPY --from=stage2 /out/go-viz /go-viz\nUSER nonroot:nonroot\nENV PORT=8080\nEXPOSE 8080\nENTRYPOINT [\"/go-viz\"]\n\nImage size: ~12\u201318 MB (Go binary only)\nNo shell, no package manager,\nno writable paths except $TMPDIR.",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#0f172a",
      "backgroundColor": "transparent",
