    {
      "type": "text",
      "id": "s3_t",
      "x": 850,
      "y": 168,
      "width": 320,
      "height": 22,
      "text": "Stage 3 \u2014 runtime (distroless/static)",
      "originalText": "Stage 3 \u2014 runtime (distroless/static)",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "top",
      "strokeColor": "#047857",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
