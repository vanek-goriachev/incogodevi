    {
      "type": "text",
      "id": "s2_t",
      "x": 450,
      "y": 168,
      "width": 340,
      "height": 22,
      "text": "Stage 2 \u2014 backend (golang:1.26-alpine)",
      "originalText": "Stage 2 \u2014 backend (golang:1.26-alpine)",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "top",
      "strokeColor": "#1e40af",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 600015,
      "version": 1,
      "versionNonce": 600016,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "containerId": null,
      "lineHeight": 1.3
    },
    {
      "type": "text",
      "id": "s2_b",
      "x": 450,
      "y": 195,
      "width": 340,
      "height": 200,
      "text": "WORKDIR /src\nCOPY server/go.mod server/go.sum ./\nRUN go mod download\nCOPY server/ ./\nCOPY --from=stage1 /web/dist /src/web/dist\nRUN CGO_ENABLED=0 \\\n    GOOS=$TARGETOS GOARCH=$TARGETARCH \\\n    go build -trimpath -ldflags=\"-s -w\" \\\n    -o /out/go-viz ./cmd/server\n// embed.FS picks up /src/web/dist",
      "originalText": "WORKDIR /src\nCOPY server/go.mod server/go.sum ./\nRUN go mod download\nCOPY server/ ./\nCOPY --from=stage1 /web/dist /src/web/dist\nRUN CGO_ENABLED=0 \\\n    GOOS=$TARGETOS GOARCH=$TARGETARCH \\\n    go build -trimpath -ldflags=\"-s -w\" \\\n    -o /out/go-viz ./cmd/server\n// embed.FS picks up /src/web/dist",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#0f172a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
