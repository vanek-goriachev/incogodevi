    {
      "type": "text",
      "id": "leg_t",
      "x": 72,
      "y": 1120,
      "width": 1100,
      "height": 18,
      "text": "Why distroless?  Minimum attack surface (no shell, no apt, no busybox) and smallest multi-arch image. `USER nonroot` \u2192 no root at runtime (NFR-13).",
      "originalText": "Why distroless?  Minimum attack surface (no shell, no apt, no busybox) and smallest multi-arch image. `USER nonroot` \u2192 no root at runtime (NFR-13).",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#334155",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 600083,
      "version": 1,
      "versionNonce": 600084,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "containerId": null,
      "lineHeight": 1.3
    },
    {
      "type": "text",
      "id": "leg_t2",
      "x": 72,
      "y": 1145,
      "width": 1100,
      "height": 18,
      "text": "Why embed.FS?  Zero runtime filesystem coupling for assets. Single artifact to ship, test, and version. Same binary on macOS dev, Linux CI, and ARM cluster.",
      "originalText": "Why embed.FS?  Zero runtime filesystem coupling for assets. Single artifact to ship, test, and version. Same binary on macOS dev, Linux CI, and ARM cluster.",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#334155",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 600085,
      "version": 1,
      "versionNonce": 600086,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "containerId": null,
      "lineHeight": 1.3
    },
    {
      "type": "text",
      "id": "leg_t3",
      "x": 72,
      "y": 1170,
      "width": 1100,
      "height": 18,
      "text": "Not shown:  reverse proxy / TLS (out of scope for MVP \u2014 expect Caddy/nginx in front for LAN deployments; localhost over HTTP is fine for the course defense).",
      "originalText": "Not shown:  reverse proxy / TLS (out of scope for MVP \u2014 expect Caddy/nginx in front for LAN deployments; localhost over HTTP is fine for the course defense).",
