    {"type": "text", "id": "deps_t1", "x": 1490, "y": 215, "width": 260, "height": 24,
     "text": "External Go packages",
     "originalText": "External Go packages",
     "fontSize": 14, "fontFamily": 3, "textAlign": "center", "verticalAlign": "top",
     "strokeColor": "#1e40af", "backgroundColor": "transparent",
     "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
